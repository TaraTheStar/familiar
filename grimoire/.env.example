# stackend per-deployment config. Copy to .env and fill in your values:
#   cp .env.example .env
# .env is gitignored — your real values (and the LLM key) are never committed.
# compose.yaml interpolates each of these as ${VAR}.

# LAN address of the host running stackend. The device dials this for the
# WebSocket session and the vision callback. Must match the OTA URL flashed
# into the firmware (menuconfig CONFIG_OTA_URL ->
# http://<LAN_IP>:9099/grimoire/ota/).
LAN_IP=192.0.2.10

# OpenAI-compatible LLM endpoint (llama-swap). Set to your real host.
LLM_URL=http://192.0.2.20:8080

# Model name as registered with llama-swap.
LLM_MODEL=gemma4-26B-A4B

# Bearer token for the LLM endpoint. SECRET — keep it only in .env.
LLM_API_KEY=sk-REPLACE_ME

# IANA timezone the get_current_time tool reports in. Optional; compose
# defaults to America/New_York if this is unset.
TIMEZONE=America/New_York
